generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SALES
  EDITOR
  SUPPORT
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  SAMPLE_SENT
  WON
  LOST
  INVALID
}

enum InquiryType {
  GENERAL
  PRODUCT
  QUOTE
  CUSTOMIZATION
  WARRANTY
  SUPPORT
}

enum ContactMethod {
  EMAIL
  PHONE
  WHATSAPP
  WECHAT
  FORM
  OTHER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LocaleCode {
  EN
  ZH_CN
  JA
  AR
}

model AdminUser {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  role          AdminRole
  displayName   String
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  leadNotes     LeadNote[]
  leadActivities LeadActivity[]
  auditLogs     AuditLog[]
}

model Locale {
  id          String      @id @default(cuid())
  code        LocaleCode  @unique
  label       String
  isDefault   Boolean     @default(false)
  isEnabled   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model LeadSource {
  id          String      @id @default(cuid())
  key         String      @unique
  label       String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  inquiries   Inquiry[]
  customers   Customer[]
}

model Customer {
  id                    String         @id @default(cuid())
  companyName           String?
  website               String?
  countryCode           String?
  region                String?
  city                  String?
  addressLine1          String?
  addressLine2          String?
  postalCode            String?
  preferredLocale       LocaleCode?
  preferredContactMethod ContactMethod?
  notes                 String?
  sourceId              String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  source                LeadSource?    @relation(fields: [sourceId], references: [id])
  contacts              Contact[]
  inquiries             Inquiry[]
  leadActivities        LeadActivity[]
}

model Contact {
  id              String        @id @default(cuid())
  customerId      String
  firstName       String?
  lastName        String?
  fullName        String?
  email           String?
  phone           String?
  whatsapp        String?
  wechat          String?
  jobTitle        String?
  isPrimary       Boolean       @default(false)
  preferredMethod ContactMethod?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Inquiry {
  id                    String         @id @default(cuid())
  inquiryType           InquiryType
  status                LeadStatus     @default(NEW)
  customerId            String?
  sourceId              String?
  assignedToAdminId     String?
  productId             String?
  subject               String?
  message               String?
  requestedQuantity     Int?
  budgetRange           String?
  shippingDestination   String?
  requestedIncoterm     String?
  preferredContactMethod ContactMethod?
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  contactWhatsapp       String?
  contactWechat         String?
  companyName           String?
  countryCode           String?
  locale                LocaleCode?
  referrerUrl           String?
  landingPageUrl        String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmTerm               String?
  utmContent            String?
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  customer              Customer?      @relation(fields: [customerId], references: [id])
  source                LeadSource?    @relation(fields: [sourceId], references: [id])
  product               Product?       @relation(fields: [productId], references: [id])
  notes                 LeadNote[]
  activities            LeadActivity[]

  @@index([status])
  @@index([customerId])
  @@index([productId])
  @@index([sourceId])
}

model LeadNote {
  id          String      @id @default(cuid())
  inquiryId   String
  adminUserId String
  body        String
  createdAt   DateTime    @default(now())

  inquiry     Inquiry     @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  adminUser   AdminUser   @relation(fields: [adminUserId], references: [id])

  @@index([inquiryId])
}

model LeadActivity {
  id           String      @id @default(cuid())
  inquiryId    String?
  customerId   String?
  adminUserId  String?
  activityType String
  summary      String
  metadataJson Json?
  createdAt    DateTime    @default(now())

  inquiry      Inquiry?    @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  customer     Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  adminUser    AdminUser?  @relation(fields: [adminUserId], references: [id])

  @@index([inquiryId])
  @@index([customerId])
}

model ProductCategory {
  id              String                       @id @default(cuid())
  parentId        String?
  slug            String                       @unique
  sortOrder       Int                          @default(0)
  isActive        Boolean                      @default(true)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  parent          ProductCategory?             @relation("CategoryTree", fields: [parentId], references: [id])
  children        ProductCategory[]            @relation("CategoryTree")
  translations    ProductCategoryTranslation[]
  products        Product[]
}

model ProductCategoryTranslation {
  id            String          @id @default(cuid())
  categoryId    String
  locale        LocaleCode
  name          String
  description   String?
  seoTitle      String?
  seoDescription String?

  category      ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Product {
  id                    String                @id @default(cuid())
  categoryId            String
  sku                   String?               @unique
  slug                  String                @unique
  status                ContentStatus         @default(DRAFT)
  coverMediaId          String?
  brochureMediaId       String?
  youtubeUrl            String?
  isFeatured            Boolean               @default(false)
  sortOrder             Int                   @default(0)
  voltage               String?
  powerConsumption      String?
  dimensions            String?
  weight                String?
  screenSize            String?
  playerCount           Int?
  moq                   Int?
  leadTimeDays          Int?
  warrantyMonths        Int?
  targetVenue           String?
  customizationEnabled  Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  category              ProductCategory       @relation(fields: [categoryId], references: [id])
  translations          ProductTranslation[]
  specs                 ProductSpec[]
  mediaItems            ProductMedia[]
  customizationOptions  ProductCustomizationOption[]
  inquiries             Inquiry[]

  @@index([categoryId])
  @@index([status])
}

model ProductTranslation {
  id               String       @id @default(cuid())
  productId        String
  locale           LocaleCode
  name             String
  shortDescription String?
  description      String?
  seoTitle         String?
  seoDescription   String?

  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductSpec {
  id          String      @id @default(cuid())
  productId   String
  sortOrder   Int         @default(0)
  specKey     String
  specValue   String
  locale      LocaleCode?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductCustomizationOption {
  id          String      @id @default(cuid())
  productId   String
  sortOrder   Int         @default(0)
  optionKey   String
  optionValue String
  locale      LocaleCode?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model MediaFile {
  id            String        @id @default(cuid())
  storageKey    String        @unique
  originalName  String
  mimeType      String
  fileSize      Int
  width         Int?
  height        Int?
  altText       String?
  uploadedById  String?
  createdAt     DateTime      @default(now())

  uploadedBy    AdminUser?    @relation(fields: [uploadedById], references: [id])
  productLinks  ProductMedia[]
}

model ProductMedia {
  id           String      @id @default(cuid())
  productId    String
  mediaFileId  String
  sortOrder    Int         @default(0)
  isPrimary    Boolean     @default(false)

  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaFile    MediaFile   @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model BlogCategory {
  id            String                   @id @default(cuid())
  slug          String                   @unique
  sortOrder     Int                      @default(0)
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  translations  BlogCategoryTranslation[]
  posts         BlogPost[]
}

model BlogCategoryTranslation {
  id             String       @id @default(cuid())
  blogCategoryId String
  locale         LocaleCode
  name           String
  description    String?

  blogCategory   BlogCategory @relation(fields: [blogCategoryId], references: [id], onDelete: Cascade)

  @@unique([blogCategoryId, locale])
}

model BlogPost {
  id             String        @id @default(cuid())
  categoryId     String?
  slug           String        @unique
  status         ContentStatus @default(DRAFT)
  coverMediaId   String?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category       BlogCategory? @relation(fields: [categoryId], references: [id])
  translations   BlogPostTranslation[]

  @@index([status])
  @@index([publishedAt])
}

model BlogPostTranslation {
  id             String      @id @default(cuid())
  postId         String
  locale         LocaleCode
  title          String
  excerpt        String?
  content        String
  seoTitle       String?
  seoDescription String?

  post           BlogPost    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

model StaticPage {
  id             String                  @id @default(cuid())
  pageKey         String                 @unique
  status          ContentStatus          @default(DRAFT)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  translations    StaticPageTranslation[]
}

model StaticPageTranslation {
  id              String      @id @default(cuid())
  pageId          String
  locale          LocaleCode
  title           String
  content         String
  seoTitle        String?
  seoDescription  String?

  page            StaticPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
}

model SiteSetting {
  id            String      @id @default(cuid())
  settingKey    String      @unique
  settingValue  Json
  updatedAt     DateTime    @updatedAt
}

model AuditLog {
  id            String      @id @default(cuid())
  adminUserId   String?
  action        String
  resourceType  String
  resourceId    String?
  metadataJson  Json?
  createdAt     DateTime    @default(now())

  adminUser     AdminUser?  @relation(fields: [adminUserId], references: [id])

  @@index([resourceType, resourceId])
}
