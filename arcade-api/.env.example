# Server
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:CHANGE_ME@postgres:5432/arcade_trade?schema=public"

# Auth
JWT_ACCESS_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING

# CORS — comma-separated for multiple origins
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# Media URLs — the public base URL of this API (how the frontend reaches it)
API_BASE_URL=https://api.your-domain.com/api/v1

# Media Storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# Hotlink Protection — comma-separated allowed domains
ALLOWED_DOMAINS=your-domain.com,www.your-domain.com

# Newsletter (frontend URL for unsubscribe links)
SITE_URL=https://your-domain.com
